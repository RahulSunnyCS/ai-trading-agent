{
  "name": "ai-trading-agent",
  "version": "0.1.0",
  "description": "Paper-trading research platform for weekly index options strategies on Indian markets",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "sim": "SIMULATE=true bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --coverage",
    "typecheck": "bun run --bun tsc --noEmit",
    "lint": "[ -f ./tools/biome ] && ./tools/biome check . || echo 'biome not installed — run: bash scripts/install-biome.sh'",
    "lint:fix": "[ -f ./tools/biome ] && ./tools/biome check --write . || echo 'biome not installed — run: bash scripts/install-biome.sh'",
    "format": "[ -f ./tools/biome ] && ./tools/biome format --write . || echo 'biome not installed — run: bash scripts/install-biome.sh'",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "bullmq": "^5.13.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.0",
    "fyers-api-v3": "^1.8.0",
    "ioredis": "^5.3.2",
    "lightweight-charts": "^4.2.0",
    "otplib": "^13.4.0",
    "pg": "^8.13.0",
    "razorpay": "^2.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "smartapi-javascript": "^1.0.27",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.0",
    "fast-check": "^4.8.0",
    "lefthook": "^2.1.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "trustedDependencies": ["esbuild", "msgpackr-extract"]
}
