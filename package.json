{
  "name": "ai-trading-agent",
  "version": "0.1.0",
  "description": "Paper-trading research platform for weekly index options strategies on Indian markets",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "sim": "SIMULATE=true bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "bullmq": "^5.0.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.6.0",
    "fastify": "^4.28.0",
    "fyers-api-v3": "^1.8.0",
    "ioredis": "^5.3.0",
    "otplib": "^13.4.0",
    "pg": "^8.11.0",
    "smartapi-javascript": "^1.0.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.1.6",
    "fast-check": "^4.8.0",
    "lefthook": "^2.1.6",
    "vitest": "^2.0.0"
  },
  "trustedDependencies": ["@biomejs/biome", "esbuild", "msgpackr-extract"]
}
