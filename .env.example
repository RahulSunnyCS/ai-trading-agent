# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trading:trading_dev@localhost:5432/trading
REDIS_URL=redis://localhost:6379

# ── Market Data ───────────────────────────────────────────────────────────────
# NSE/BSE WebSocket feed (Zerodha Kite / Upstox / Angel SmartAPI etc.)
NSE_WEBSOCKET_URL=wss://your-broker-websocket-url
NSE_API_KEY=your_api_key
NSE_ACCESS_TOKEN=your_access_token

# Quantiply paper trading API
QUANTIPLY_API_URL=https://api.quantiply.in
QUANTIPLY_API_KEY=your_quantiply_api_key

# ── Signal Parameters ─────────────────────────────────────────────────────────
SIGNAL_MIN_EXPANSION_PCT=10
SIGNAL_ACCELERATION_THRESHOLD=-0.5
SIGNAL_CONFIRMATION_CANDLES=3

# ── Evolution ─────────────────────────────────────────────────────────────────
EVOLUTION_REQUIRE_APPROVAL=true
EVOLUTION_COOLDOWN_DAYS=3

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Simulation (dev mode — set to true to run without real broker connection) ─
SIMULATE=false
SIM_UNDERLYING=NIFTY
SIM_TICK_INTERVAL_MS=1000
