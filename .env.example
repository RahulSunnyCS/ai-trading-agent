# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trading:trading_dev@localhost:5432/trading
REDIS_URL=redis://localhost:6379

# ── Broker: Fyers ─────────────────────────────────────────────────────────────
# Why Fyers over Angel One:
#   - Option symbols are string-based (NSE:NIFTY255824000CE) — no scripmaster needed.
#     New weekly contracts listed every Thursday are addressed by constructing the
#     symbol string. Angel One requires downloading and parsing a large token file.
#   - VIX subscribed directly as NSE:INDIAVIX-INDEX tick.
#   - Single stable token. Angel One jwtToken expires daily and needs automated refresh.
#
# How to get credentials:
#   1. Log in to Fyers API Dashboard: https://myapi.fyers.in/dashboard
#   2. Create an app → note your App ID (client_id)
#   3. Generate an access token via OAuth flow (daily; automate with fyers-api-v3 auth API)
#   4. Token format for data socket: "{APP_ID}:{ACCESS_TOKEN}"
FYERS_APP_ID=XXXXXXXXXXXX-100          # your Fyers App ID
FYERS_ACCESS_TOKEN=your_access_token   # OAuth token (regenerate daily or automate)

# ── Quantiply paper trading API ────────────────────────────────────────────────
QUANTIPLY_API_URL=https://api.quantiply.in
QUANTIPLY_API_KEY=your_quantiply_api_key

# ── Signal Parameters ─────────────────────────────────────────────────────────
SIGNAL_MIN_EXPANSION_PCT=10
SIGNAL_ACCELERATION_THRESHOLD=-0.5
SIGNAL_CONFIRMATION_CANDLES=3

# ── Evolution ─────────────────────────────────────────────────────────────────
EVOLUTION_REQUIRE_APPROVAL=true
EVOLUTION_COOLDOWN_DAYS=3

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Simulation (dev mode — no broker credentials needed) ──────────────────────
SIMULATE=false
SIM_UNDERLYING=NIFTY
SIM_TICK_INTERVAL_MS=1000
