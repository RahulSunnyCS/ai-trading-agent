# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_trading_agent
# Must be PostgreSQL 16 with TimescaleDB extension. Vanilla pg:16 will fail migration.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Must be Redis 7+. BullMQ requires Redis Streams features not in Redis 6.

# ── Simulation ────────────────────────────────────────────────────────────────
SIMULATE=true
# Set to true for all local development. Omitting this → app tries Fyers and fails.

# ── Broker: Fyers (primary live market data) ─────────────────────────────────
FYERS_ACCESS_TOKEN=
# EXPIRES DAILY. Must be regenerated each morning before 9:00 AM IST.
FYERS_APP_ID=
# Format: XXXXXXXXXXXX-100 (app ID + -100 suffix)

# ── Broker: Angel One (fallback live market data) ─────────────────────────────
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# ── Paper Trading ─────────────────────────────────────────────────────────────
QUANTIPLY_API_KEY=
# Required in live mode. Missing → paper trade writes fail silently.

# ── Evolution ────────────────────────────────────────────────────────────────
EVOLUTION_REQUIRE_APPROVAL=true
# Keep true in any env where retrospection engine runs. false = autonomous parameter changes.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Broker selection ─────────────────────────────────────────────────────────
BROKER=fyers
# Options: fyers | angelone. Ignored when SIMULATE=true.

# ── Payment (Razorpay — India UPI) ───────────────────────────────────────────
# Omit RAZORPAY_KEY_ID (or leave blank) for free/open access — payment mode disabled.
RAZORPAY_KEY_ID=
# Razorpay Key ID — SAFE to expose to frontend / Checkout widget (rzp_test_... or rzp_live_...)
RAZORPAY_KEY_SECRET=
# Razorpay Key Secret — SERVER-ONLY. Never expose to frontend or logs.
RAZORPAY_WEBHOOK_SECRET=
# Razorpay Webhook Signing Secret — SERVER-ONLY.
RAZORPAY_MONTHLY_PASS_PRICE_PAISE=99900
# Monthly access pass price in Indian paise. 99900 = ₹999
RAZORPAY_CREDITS_PACK_50_PRICE_PAISE=49900
# 50-credit pack price in paise. 49900 = ₹499
RAZORPAY_CREDITS_PACK_200_PRICE_PAISE=149900
# 200-credit pack price in paise. 149900 = ₹1499

# ── Geolocation ───────────────────────────────────────────────────────────────
GEOLOCATION_API_URL=https://ip-api.com/json
# Free tier: 45 req/min. Self-hosted MaxMind proxy can be substituted.
