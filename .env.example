# =============================================================================
# AI Trading Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# Must point at PostgreSQL 16 with TimescaleDB extension.
# Standard postgres:16-alpine does NOT include TimescaleDB — use the
# timescale/timescaledb image (see docker-compose.yml).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading

# Redis 7+ required — BullMQ uses Streams features absent in Redis 6
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Runtime mode
# Set SIMULATE=true for all local development — no broker credentials needed.
# Omitting this in dev causes immediate Fyers connection failure.
# -----------------------------------------------------------------------------
SIMULATE=true

# Primary broker adapter to use when SIMULATE=false
BROKER=fyers

# -----------------------------------------------------------------------------
# Fyers credentials (required for live mode — SIMULATE=false)
# FYERS_ACCESS_TOKEN expires daily. Regenerate every morning before 9:00 AM IST.
# There is no automatic refresh yet — missing this causes silent WS disconnect.
# FYERS_APP_ID format: XXXXXXXXXXXX-100 (12 chars + "-100" suffix)
# -----------------------------------------------------------------------------
FYERS_APP_ID=XXXXXXXXXXXX-100
FYERS_ACCESS_TOKEN=your-daily-token-here

# -----------------------------------------------------------------------------
# Angel One credentials (fallback broker)
# AO_CLIENT_PIN: 4-digit PIN
# AO_TOTP_SECRET: base32 TOTP seed from Angel One 2FA setup
# -----------------------------------------------------------------------------
AO_API_KEY=your-angel-api-key
AO_CLIENT_CODE=your-client-code
AO_CLIENT_PIN=your-4-digit-pin
AO_TOTP_SECRET=your-totp-secret

# -----------------------------------------------------------------------------
# Quantiply paper trade tracking API
# QUANTIPLY_API_KEY is required in live mode.
# Missing key → paper trade writes fail (check error handling is tight).
# -----------------------------------------------------------------------------
QUANTIPLY_API_KEY=your-quantiply-key
QUANTIPLY_API_URL=https://api.quantiply.in

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# Simulation settings (only used when SIMULATE=true)
# SIM_TICK_INTERVAL_MS: how often the random-walk simulator emits a tick
# -----------------------------------------------------------------------------
SIM_TICK_INTERVAL_MS=500

# -----------------------------------------------------------------------------
# Trading schedule (IST, 24-hour format)
# ENTRY_TIME:        earliest time a personality may take a signal
# ENTRY_CUTOFF_TIME: no new entries accepted after this time
# EOD_EXIT_TIME:     start unwinding all open positions
# EXIT_CUTOFF_TIME:  hard close — any remaining positions are force-exited
# -----------------------------------------------------------------------------
ENTRY_START_TIME=09:20
ENTRY_CUTOFF_TIME=14:30
EOD_EXIT_TIME=15:25
EXIT_CUTOFF_TIME=15:30

# -----------------------------------------------------------------------------
# Risk management thresholds (fractional, e.g. 0.30 = 30%)
# HARD_SL_PCT:        hard stop-loss % from entry straddle value
# TRAILING_SL_PCT:    trailing stop % once trade is profitable
# PROFIT_TARGET_PCT:  take-profit % from entry straddle value
# MAX_DAILY_LOSS:     absolute INR daily loss limit across all personalities
# -----------------------------------------------------------------------------
HARD_SL_PCT=0.30
TRAILING_SL_PCT=0.15
PROFIT_TARGET_PCT=0.30
MAX_DAILY_LOSS=10000

# -----------------------------------------------------------------------------
# Evolution engine
# EVOLUTION_REQUIRE_APPROVAL=true means rule-based parameter changes queue for
# human approval before being applied. Set false to allow autonomous evolution —
# do this only in controlled experiments, never in production.
# -----------------------------------------------------------------------------
EVOLUTION_REQUIRE_APPROVAL=true

# -----------------------------------------------------------------------------
# Blocked trading dates
# JSON array of YYYY-MM-DD strings. Personalities will not enter new trades on
# these dates. Pre-populated with 2026 NSE weekly F&O expiry Thursdays.
# Add RBI policy days, budget day, and any exchange-declared holidays here.
# -----------------------------------------------------------------------------
BLOCKED_DATES=["2026-01-29","2026-02-26","2026-03-26","2026-04-30","2026-05-28","2026-06-25","2026-07-30","2026-08-27","2026-09-24","2026-10-29","2026-11-26","2026-12-31"]
